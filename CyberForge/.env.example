# Root-level environment variables for docker-compose
# Copy to .env and customize for your environment

# ============================================================================
# DOCKER COMPOSE
# ============================================================================
COMPOSE_PROJECT_NAME=cyberforge

# ============================================================================
# DATABASE (PostgreSQL 16+)
# ============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cyberforge_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/cyberforge_db

# ============================================================================
# API (NestJS Backend)
# ============================================================================
API_PORT=3000
API_HOST=0.0.0.0
NODE_ENV=production
API_LOG_LEVEL=info

# JWT Configuration
# Generate secrets via: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=900  # 15 minutes in seconds
REFRESH_TOKEN_SECRET=your-refresh-token-secret-change-in-production
REFRESH_TOKEN_EXPIRATION=604800  # 7 days in seconds

# Data Encryption (envelope encryption for secrets)
# Generate via: openssl rand -base64 32
DATA_KEY_ENCRYPTION_KEY=your-data-encryption-key-change-in-production

# Security
RATE_LIMIT_WINDOW_MS=60000  # 1 minute
RATE_LIMIT_MAX_REQUESTS=100

# Login rate limiting (brute-force protection)
LOGIN_RATE_LIMIT_WINDOW_MS=60000  # 1 minute
LOGIN_RATE_LIMIT_MAX_REQUESTS=5

# CORS Configuration
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true

# Session Configuration
SESSION_SECRET=your-session-secret-change-in-production

# ============================================================================
# WEB (Next.js Frontend)
# ============================================================================
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ENV=production

# ============================================================================
# OPTIONAL: REDIS (for caching, real-time subscriptions)
# ============================================================================
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# OPTIONAL: SMTP (for alert notifications, password reset emails)
# ============================================================================
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# For production, integrate with centralized logging (e.g., ELK, Datadog, Cloudwatch)
LOG_FORMAT=json  # Options: json, text
SENTRY_DSN=  # Optional: Sentry error tracking

# ============================================================================
# SECURITY HEADERS
# ============================================================================
ENABLE_HSTS=true
HSTS_MAX_AGE=31536000  # 1 year
ENABLE_CSP=true
CSP_HEADER="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'"

# ============================================================================
# INGESTION (Data Collection from Sensors/Devices)
# ============================================================================
INGESTION_API_KEY_HEADER=X-API-Key
INGESTION_REQUIRE_MTLS=false  # Set to true for mTLS + client cert validation

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_WEBHOOK_NOTIFICATIONS=true
ENABLE_REAL_TIME_ALERTS=true
ENABLE_AUDIT_LOG_EXPORT=true
